# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=ForFabMetalsSystem
DB_USER=sa
DB_PASSWORD=123456
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Sessão (gere uma chave aleatória segura)
SESSION_SECRET=forfabio_chave_super_secreta_troque_isso_em_producao_2026

# Limite de upload de arquivos (em MB)
UPLOAD_SIZE_LIMIT_MB=10
